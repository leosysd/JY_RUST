# ── 运行模式 ──────────────────────────────────────────────────
BOT_MODE=quant
DRY_RUN=1                         # 1=模拟  0=实盘

# ── 钱包/签名 ─────────────────────────────────────────────────
PRIVATE_KEY=                      # 交易钱包私钥（实盘必填）
DEPOSIT_WALLET_ADDRESS=           # Polymarket 个人资料页的 0x... 地址
CHAIN_ID=137
SIGNATURE_TYPE=3

# ── API ────────────────────────────────────────────────────────
CLOB_API_URL=https://clob.polymarket.com

# ── 策略选择 ──────────────────────────────────────────────────
# jetfadil = JetFadil 锁利策略（推荐）
# copy     = 跟单模式
# arb      = 纯套利
QUANT_STRATEGY=jetfadil

# ── JetFadil 策略参数 ─────────────────────────────────────────
QUANT_ORDER_SHARES=20             # 每笔固定份数
QUANT_ARBITRAGE_MIN_PROFIT=0.15   # 最低锁利利润（15%）
JF_MIN_ENTRY_PRICE=0.44
JF_MAX_ENTRY_PRICE=0.65
JF_MAX_ENTRY_DELAY_SEC=30         # 开盘后最大入场延迟（秒）
QUANT_MIN_SECONDS_LEFT=5

# ── Copy 跟单参数 ─────────────────────────────────────────────
TARGET_WALLET=0xe0229e10a858860218b6132f4234602c47bd6603
COPY_RATIO=1.0
PRICE_MODE=safe                   # safe / aggressive
MAX_SLIPPAGE=0.02

# ── 系统 ──────────────────────────────────────────────────────
POLL_MS=1000
QUANT_STATE_FILE=quant_state.json
QUANT_SIGNAL_FILE=data/quant_signals.jsonl
LOG_FILE=logs/jy-bot.log
