# ── 运行模式 ──────────────────────────────────────────────────
DRY_RUN=1                         # 1=模拟  0=实盘

# ── 钱包/签名 ─────────────────────────────────────────────────
PRIVATE_KEY=                      # 交易钱包私钥（实盘必填）
DEPOSIT_WALLET_ADDRESS=           # Polymarket 个人资料页的 0x... 地址
CHAIN_ID=137
SIGNATURE_TYPE=3

# ── API ────────────────────────────────────────────────────────
CLOB_API_URL=https://clob.polymarket.com
CLOB_V2_API_URL=https://clob.polymarket.com

# ── 入场策略 ──────────────────────────────────────────────────
# sniper  = 延迟套利狙击:盘内监控binance,BTC突破→抢盘口反应延迟(30天回测净edge+5.7%,推荐)
# ev_solo = z-score定方向+单边裸持(开盘预测,实测开盘方向≈抛硬币54%,已被sniper取代)
# zscore  = z-score + 锁利/追单/减险(baseline,对比用)
ENTRY_STRATEGY=sniper

# ── ev_solo 参数 ──────────────────────────────────────────────
EV_SOLO_QTY=20                    # 单边份额
EV_SOLO_MIN_ASK=0.44              # 入场价下限(0.40-0.44段实测仅31%胜率坑,故抬到0.44)
EV_SOLO_MAX_ASK=0.52              # 入场价上限(>此值负EV区,跳过)
EV_SOLO_MIN_SECONDS_LEFT=240      # 入场最早时点:剩余≥此值才入(240=只打开盘头60s,砍晚场低胜率尾巴)
EV_SOLO_FLOW_GATE=1               # 1=开盘前30s资金流(flow_imb_30)与z方向相悖则跳过该盘
TAKER_BUFFER=0.02                 # taker吃单滑点缓冲(限价=ask+此值);调大减扑空,代价滑点+

# ── sniper 延迟套利狙击 参数(ENTRY_STRATEGY=sniper 时用)──────────
# 原理:盘内监控binance,BTC相对开盘动够SNIPER_MOVE_USD即定方向(涨买Up/跌买Down),
# 仅当对应方向ask<SNIPER_MAX_ASK(盘口还没反应)时FAK买入、裸持到结算。赚盘口反应延迟。
SNIPER_MOVE_USD=20               # BTC相对参照价动够此美元数才定方向(30天回测±$20最优)
SNIPER_WINDOW_SEC=0              # 0=相对开盘累计;>0=最近N秒内变动(5=纯速度版,更抓快突破)
SNIPER_MAX_ASK=0.62              # 限价闸(灵魂):仅ask<此值才买,盘口已反应(贵)则放弃。0.50-0.60段净edge最肥
SNIPER_QTY=20                    # 单边份额(实盘小额测试建议先填1)

# ── zscore baseline 参数(ENTRY_STRATEGY=zscore 时用)──────────
QUANT_ORDER_SHARES=20
LOCK_MIN_PROFIT_FACTOR=0.25
TREND_CHASE_MAX_PRICE=0.60
FORCE_LOCK_SECONDS_LEFT=60
FORCE_LOSS_MODE=naked             # naked=方向错裸持到结算(不对锁);smooth/lock=旧行为

# ── 系统 ──────────────────────────────────────────────────────
POLL_MS=200                       # 兜底轮询(事件驱动为主,此为冷场保底)
QUANT_STATE_FILE=quant_state.json
QUANT_SIGNAL_FILE=data/quant_signals.jsonl
LOG_FILE=logs/jy-bot.log

# ── 盘口数据采集(常驻,与交易无关)──────────────────────────────
BOOK_RECORD_ENABLED=1             # 一启动即录每盘逐tick盘口(LightGBM训练数据)
