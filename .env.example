# ── 运行模式 ──────────────────────────────────────────────────
DRY_RUN=1                         # 1=模拟  0=实盘

# ── 钱包/签名 ─────────────────────────────────────────────────
PRIVATE_KEY=                      # 交易钱包私钥（实盘必填）
DEPOSIT_WALLET_ADDRESS=           # Polymarket 个人资料页的 0x... 地址
CHAIN_ID=137
SIGNATURE_TYPE=3

# ── API ────────────────────────────────────────────────────────
CLOB_API_URL=https://clob.polymarket.com
CLOB_V2_API_URL=https://clob.polymarket.com

# ── 入场策略 ──────────────────────────────────────────────────
# sniper  = 延迟套利狙击:盘内监控binance,BTC突破→抢盘口反应延迟(30天回测净edge+5.7%,推荐)
# ev_solo = z-score定方向+单边裸持(开盘预测,实测开盘方向≈抛硬币54%,已被sniper取代)
# zscore  = z方向入场(默认币安方向,见 ZSCORE_*) + 锁利/追单/减险;入场过滤独立可调,不影响其它策略
# accum   = z定主腿方向→谁涨追谁(0.62-0.70)/谁跌补谁(0.28-0.20,计算模块算份额)→赢≥12/亏≤7锁住即停
ENTRY_STRATEGY=sniper

# ── ev_solo 参数 ──────────────────────────────────────────────
EV_SOLO_QTY=20                    # 单边份额
EV_SOLO_MIN_ASK=0.44              # 入场价下限(0.40-0.44段实测仅31%胜率坑,故抬到0.44)
EV_SOLO_MAX_ASK=0.52              # 入场价上限(>此值负EV区,跳过)
EV_SOLO_MIN_SECONDS_LEFT=240      # 入场最早时点:剩余≥此值才入(240=只打开盘头60s,砍晚场低胜率尾巴)
EV_SOLO_FLOW_GATE=1               # 1=开盘前30s资金流(flow_imb_30)与z方向相悖则跳过该盘
TAKER_BUFFER=0.02                 # taker吃单滑点缓冲(限价=ask+此值);调大减扑空,代价滑点+

# ── sniper 延迟套利狙击 参数(ENTRY_STRATEGY=sniper 时用)──────────
# 原理:盘内监控binance,BTC相对开盘动够SNIPER_MOVE_USD即定方向(涨买Up/跌买Down),
# 仅当对应方向ask<SNIPER_MAX_ASK(盘口还没反应)时FAK买入、裸持到结算。赚盘口反应延迟。
SNIPER_MOVE_USD=20               # BTC相对参照价动够此美元数才定方向(30天回测±$20最优)
SNIPER_WINDOW_SEC=0              # 0=相对开盘累计;>0=最近N秒内变动(5=纯速度版,更抓快突破)
SNIPER_MAX_ASK=0.62              # 限价闸(灵魂):仅ask<此值才买,盘口已反应(贵)则放弃。0.50-0.60段净edge最肥
SNIPER_QTY=20                    # 单边份额(实盘小额测试建议先填1)

# ── accum 双边追涨补仓+计算模块 参数(ENTRY_STRATEGY=accum 时用)──────────
# 首笔z定主腿方向(锚点不换)。之后每tick对Up/Down两边:谁涨追谁、谁跌补谁(计算模块算份额),
# 把结算锁到「主腿赢≥TARGET_WIN、主腿输≥−MAX_LOSS」,两情景都达标即停止下单裸持。
ACCUM_QTY=20                     # 首笔/追买份额(每档固定;实盘小额先填1)
ACCUM_ENTRY_Z=0.15               # 首笔定方向阈值:|z|≥此值才开首笔主腿
ACCUM_CHASE_LEVELS=0.62,0.65,0.68,0.70   # 追涨档(谁涨追谁):任一边ask≥某档→追买那边
ACCUM_DIP_LEVELS=0.25,0.20       # 补仓档(谁跌补谁):任一边ask≤某档→计算模块补那边
ACCUM_TARGET_WIN=12              # 计算模块:主腿方向赢的结算PnL目标(补到≥此值)
ACCUM_MAX_LOSS=7                 # 计算模块:主腿方向输的最大亏损(补到结算PnL≥−此值)
ACCUM_FORCE_SECONDS=15           # 临近结算停建:剩余秒≤此值不再下单
# 晚场顺势补救(未锁盘临结算补救):剩余<RESCUE_SECS、某边ask∈(LO,HI)收敛带、本盘未锁住→
# 顺势补强势边到"该边赢结算>RESCUE_GOAL"(cap不限)。6/6回测全局-408→+132,命中≈88%。
# 注意是正EV×杠杆:命中赚/翻盘亏更大,靠88%命中率撑,需多天DRY_RUN验证命中率是否稳。
ACCUM_RESCUE_SECS=100            # 剩余秒<此值才触发(临结算市场已收敛区,=开盘后≥200s)
ACCUM_RESCUE_LO=0.78             # 收敛带下限
ACCUM_RESCUE_HI=0.83             # 收敛带上限
ACCUM_RESCUE_GOAL=10             # 顺势补强势边到该边赢结算PnL>此值

# ── zscore 参数(ENTRY_STRATEGY=zscore 时用)──────────
# zscore = z方向入场 + 锁利/追单/减险(持仓管理)。入场过滤与方向公式均「独立」于其它策略,
# 改下面 ZSCORE_* 不会影响 ev_solo/accum/zquote。份额用全局 QUANT_ORDER_SHARES(不单设)。
ZSCORE_USE_BINANCE_DIR=1          # 方向公式:1=币安驱动(币安现价基差校正相对开盘价+币安动量);0=Chainlink原混合公式
ZSCORE_MIN_ASK=0.44               # 入场价下限(默认同ev_solo,可单独调)
ZSCORE_MAX_ASK=0.52               # 入场价上限(>此值跳过)
ZSCORE_MIN_SECONDS_LEFT=240       # 入场最早时点:剩余≥此值才入(240=只打开盘头60s)
ZSCORE_FLOW_GATE=1                # 1=开盘前30s资金流(flow_imb_30)与z方向相悖则跳过该盘
# 持仓管理(入场后):
QUANT_ORDER_SHARES=20             # 全局下单份额(zscore 用它;与 EV_SOLO_QTY/SNIPER_QTY/ACCUM_QTY 同步)
LOCK_MIN_PROFIT_FACTOR=0.25
TREND_CHASE_MAX_PRICE=0.60
FORCE_LOCK_SECONDS_LEFT=60
FORCE_LOSS_MODE=naked             # naked=方向错裸持到结算(不对锁);smooth/lock=旧行为

# ── 系统 ──────────────────────────────────────────────────────
POLL_MS=200                       # 兜底轮询(事件驱动为主,此为冷场保底)
QUANT_STATE_FILE=quant_state.json
QUANT_SIGNAL_FILE=data/quant_signals.jsonl
LOG_FILE=logs/jy-bot.log

# ── 盘口数据采集(常驻,与交易无关)──────────────────────────────
BOOK_RECORD_ENABLED=1             # 一启动即录每盘逐tick盘口(LightGBM训练数据)
Z_RECORD_ENABLED=1                # 一启动即录盘内逐秒真z(phase=z_tick:z/p_up/e/v/σ120+两边ask),为"盘内便宜边+真z"回测攒数据
